# NFL Predictor — Environment Variables
# Copy this to .env and fill in your values
# cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
WEB_CONCURRENCY=2        # Number of Gunicorn workers (2 is fine for most machines)
LOG_LEVEL=INFO

# ── Redis (optional but recommended) ─────────────────────────────────────────
# Without Redis the app uses an in-process cache (works fine, no persistence)
# With Docker: REDIS_URL=redis://redis:6379/0
# With local Redis: REDIS_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Vegas Odds (optional) ─────────────────────────────────────────────────────
# Free tier at https://the-odds-api.com — 500 requests/month
# Without a key the app shows estimated odds derived from team stats
ODDS_API_KEY=a49d3d05b807011cbe53c9d3f1f84c67

# ── Model ─────────────────────────────────────────────────────────────────────
# xgboost (default) | lightgbm | sklearn
NFL_MODEL_TYPE=xgboost
